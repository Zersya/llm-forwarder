# ============================================
# LLM Forwarder - Environment Configuration
# ============================================

# ===== YOUR LLM PROVIDER CONFIGURATION =====
# These are the credentials for your LLM backend

# Your API key for the LLM provider
LLM_API_KEY=your-api-key-here

# Base URL for the LLM API (OpenAI compatible)
# Examples:
#   - https://api.openai.com/v1
#   - https://api.fireworks.ai/inference/v1
#   - https://your-custom-endpoint.com/v1
#   - http://localhost:11434/v1 (Ollama local)
API_BASE_URL=https://api.openai.com/v1

# Model name as it appears in the provider
# Examples:
#   - gpt-4o
#   - fireworks/accounts/fireworks/models/llama-v3_1-70b-instruct
#   - ollama/llama3
MODEL_NAME=gpt-4o

# Model alias users will use (friendly name)
MODEL_ALIAS=custom-model

# Rate limits for the backend (optional)
# RPM=1000
# TPM=60000

# Model pricing per 1M tokens (optional - for cost tracking)
# INPUT_PRICE_PER_M=0.6
# OUTPUT_PRICE_PER_M=3.5

# ===== ADMIN CONFIGURATION =====
# Master key for admin access (change this!)
# Used to manage API keys and view analytics
MASTER_KEY=sk-admin-change-this-in-production

# ===== DATABASE =====
# SQLite database path (auto-set in docker-compose)
# DATABASE_URL=sqlite:///app/data/litellm.db

# ===== OPTIONAL CONFIGURATION =====

# Optional: LiteLLM UI credentials
# UI_USERNAME=admin
# UI_PASSWORD=change-this-too

# Optional: Redis for distributed deployments
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# Optional: Slack alerting
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Optional: Langfuse for detailed tracing
# LANGFUSE_PUBLIC_KEY=your-public-key
# LANGFUSE_SECRET_KEY=your-secret-key

STORE_MODEL_IN_DB=true